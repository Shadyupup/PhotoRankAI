# PhotoRank AI — Environment Variables
# Copy this file to .env and fill in your values.

# Gemini API Key (optional — can also be set via Settings UI in the app)
# Get a free key at: https://aistudio.google.com/apikey
# Required only for Fast and Pro enhancement modes.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# DashScope API Key (optional — for Alibaba Qwen model)
# Get a key at: https://dashscope.console.aliyun.com/
VITE_DASHSCOPE_API_KEY=your_dashscope_api_key_here
